# Copy this file to .env for local development.
# Do not commit real secrets.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=

# Optional. Reserved for deployments that add an app-level access gate.
APP_PASSWORD=

# Optional. Use APP_MODE=mock for local demos without live OpenAI, Anthropic,
# Qdrant, or DuckDuckGo calls. Defaults to live.
APP_MODE=live
